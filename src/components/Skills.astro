---
const icon = (slug: string) => `https://cdn.simpleicons.org/${slug}/dd501d`;
---

<div class="skills__wrapper" data-aos="fade-right">
  <h2 style="color: #1d3557">Skills</h2>

  <ul class="skills-view">
    <div class="skills-card">
      <h3>Programming Languages</h3>
      <ul class="skills-list">
        <li class="skill">
          <img src={icon("swift")} width="50" height="50" alt="Swift logo" />
          <span>Swift</span>
        </li>
        <li class="skill">
          <img src={icon("kotlin")} width="50" height="50" alt="Kotlin logo" />
          <span>Kotlin</span>
        </li>
        <li class="skill">
          <img src={icon("javascript")} width="50" height="50" alt="JavaScript logo" />
          <span>JavaScript</span>
        </li>
      </ul>
    </div>

    <div class="skills-card">
      <h3>Frontend</h3>
      <ul class="skills-list">
        <li class="skill">
          <img src={icon("html5")} width="50" height="50" alt="HTML5 logo" />
          <span>HTML5</span>
        </li>
        <li class="skill">
          <img src={icon("react")} width="50" height="50" alt="React logo" />
          <span>React</span>
        </li>
        <li class="skill">
          <img src={icon("redux")} width="50" height="50" alt="Redux logo" />
          <span>Redux</span>
        </li>
      </ul>
    </div>

    <div class="skills-card">
      <h3>Backend</h3>
      <ul class="skills-list">
        <li class="skill">
          <img src={icon("express")} width="50" height="50" alt="Express logo" />
          <span>Express</span>
        </li>
        <li class="skill">
          <img src={icon("firebase")} width="50" height="50" alt="Firebase logo" />
          <span>Firebase</span>
        </li>
        <li class="skill">
          <img src={icon("nodedotjs")} width="50" height="50" alt="Node.js logo" />
          <span>Node.js</span>
        </li>
      </ul>
    </div>
  </ul>

  <ul class="skills-view">
    <div class="skills-card">
      <h3>Hosting Platforms</h3>
      <ul class="skills-list">
        <li class="skill">
          <img src={icon("heroku")} width="50" height="50" alt="Heroku logo" />
          <span>Heroku</span>
        </li>
        <li class="skill">
          <img src={icon("firebase")} width="50" height="50" alt="Firebase logo" />
          <span>Firebase</span>
        </li>
        <li class="skill">
          <img src={icon("netlify")} width="50" height="50" alt="Netlify logo" />
          <span>Netlify</span>
        </li>
      </ul>
    </div>

    <div class="skills-card">
      <h3>Version Control</h3>
      <ul class="skills-list">
        <li class="skill">
          <img src={icon("bitbucket")} width="50" height="50" alt="Bitbucket logo" />
          <span>Bitbucket</span>
        </li>
        <li class="skill">
          <img src={icon("git")} width="50" height="50" alt="Git logo" />
          <span>Git</span>
        </li>
        <li class="skill">
          <img src={icon("github")} width="50" height="50" alt="GitHub logo" />
          <span>GitHub</span>
        </li>
      </ul>
    </div>

    <div class="skills-card">
      <h3>Databases</h3>
      <ul class="skills-list">
        <li class="skill">
          <img src={icon("firebase")} width="50" height="50" alt="Firebase logo" />
          <span>Firebase</span>
        </li>
        <li class="skill">
          <img src={icon("mongodb")} width="50" height="50" alt="MongoDB logo" />
          <span>MongoDB</span>
        </li>
        <li class="skill">
          <img src={icon("mysql")} width="50" height="50" alt="MySQL logo" />
          <span>MySQL</span>
        </li>
      </ul>
    </div>
  </ul>
</div>
