---

<div class="cards">
  <div class="cards__hero">
    <div class="image1" data-lottie="projects-hero"></div>
    <h1>Check out my work</h1>
    <p>
      A mix of professional product work and side projects across iOS, web,
      backend, and software engineering.
    </p>
    <a href="#featured-project" class="downArrow bounce" aria-label="Scroll to featured project">
      <div data-lottie="mouse-pointer" class="cards__mouse"></div>
    </a>
  </div>

  <div id="featured-project"></div>

 <section class="featured-project" data-aos="fade-up">
  <div class="featured-project__content">
    <span class="featured-project__eyebrow">{featuredProject.eyebrow}</span>
    <p class="featured-project__note">
  One highlight from a broader set of iOS and product work I contributed to at Lowe’s.
</p>
    <h2>{featuredProject.title}</h2>
    <p class="featured-project__description">{featuredProject.description}</p>

    <div class="featured-project__techs" aria-label="Technology badges">
      {featuredProject.techs.map((tech) => (
        <img src={tech.src} alt={tech.alt} />
      ))}
    </div>

    <div class="featured-project__tags">
      {featuredProject.tags.map((tag) => (
        <span>{tag}</span>
      ))}
    </div>

    <div class="featured-project__actions">
      <a
        href={featuredProject.appStoreLink}
        target="_blank"
        rel="noopener noreferrer"
        class="featured-project__button featured-project__button--primary"
      >
        View on App Store
      </a>

      <a
        href={featuredProject.articleLink}
        target="_blank"
        rel="noopener noreferrer"
        class="featured-project__button featured-project__button--secondary"
      >
        Read about MyLow
      </a>
    </div>
  </div>

  <div class="featured-project__visual">
    <img
      src={featuredProject.logoSrc}
      alt={featuredProject.logoAlt}
      class="featured-project__corner-logo"
    />

    <div class="featured-project__image-wrap">
      <img
        src={featuredProject.imageSrc}
        alt={featuredProject.imageAlt}
        class="featured-project__image"
      />
    </div>
  </div>
</section>



  <div class="cards__divider" aria-hidden="true"></div>

  <section class="cards__side-projects">
    <div class="cards__section-heading" data-aos="fade-up">
      <span>Side Projects</span>
      <h2>Independent builds and experiments</h2>
      <p>
        Personal projects, technical explorations, and academic work across web,
        mobile, and software engineering.
      </p>
    </div>

    <div id="project"></div>

    <div class="cards__wrapper">
      {projectRows.map((row) => (
        <div data-aos="fade-left">
          <ul class="cards__items">
            {row.map((item) => (
              <CardItem {...item} />
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</div>

<script>
  import lottie from "lottie-web";
  import projectsAnimation from "../assets/data.json";
  import mouseAnimation from "../assets/LottieMouse.json";

  const hero = document.querySelector("[data-lottie='projects-hero']");
  const mouse = document.querySelector("[data-lottie='mouse-pointer']");

  if (hero) {
    requestAnimationFrame(() => {
      lottie.loadAnimation({
        container: hero,
        renderer: "svg",
        loop: true,
        autoplay: true,
        animationData: projectsAnimation,
      });
    });
  }

  if (mouse) {
    requestAnimationFrame(() => {
      lottie.loadAnimation({
        container: mouse,
        renderer: "svg",
        loop: true,
        autoplay: true,
        animationData: mouseAnimation,
      });
    });
  }
</script>
