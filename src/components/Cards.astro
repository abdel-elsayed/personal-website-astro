  eyebrow: "Professional Work",
  title: "Lowe's iOS App — MyLow AI Shopping Assistant",
  description:
    "Architected the OpenAI Realtime voice chat, owned the in-chat Apple Pay integration, and helped modernize legacy UIKit screens to SwiftUI in a production retail app.",
  logoSrc: "/images/lowes-logo.png",
  logoAlt: "Lowe's logo",
  imageSrc: "/images/mylow-screenshot.png",
  imageAlt: "Screenshot of MyLow AI shopping assistant in the Lowe's iOS app",
  appStoreLink: "https://apps.apple.com/us/app/lowes-home-improvement/id457954781",
  articleLink:
    "https://corporate.lowes.com/newsroom/press-releases/lowes-launches-first-ai-powered-home-improvement-virtual-advisor-03-05-25",
  techs: [
  icon("swift", "Swift logo"),
  icon("apple", "Apple logo"),
],
